{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Start frontend",
			"type": "shell",
			"command": "npm",
			"args": [
				"start"
			],
			"isBackground": true,
			"group": "build"
		},
		{
			"label": "Start backend",
			"type": "shell",
